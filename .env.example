
# Ollama endpoint (default local)
OLLAMA_HOST=http://localhost:11434

# Benchmark controls
BENCH_PROMPT=Write a complete kotlin async HTTP client with error handling, retry logic, and cancellation token support
BENCH_TIMEOUT_SEC=1200
BENCH_COOLDOWN_SEC=15
BENCH_SAMPLE_INTERVAL_SEC=0.5
BENCH_TEMPERATURE=0.2

# Optional: Ollama defaults (if you run ollama serve yourself)
# Ollama supports server env vars; on Windows it inherits user/system env vars. [4](https://docs.ollama.com/faq)
OLLAMA_KEEP_ALIVE=0
OLLAMA_CONTEXT_LENGTH=4096
